
import numpy as np
import matplotlib.pyplot as plt

# --- Parameters for Strong Acid vs. Strong Base Titration ---

# Strong Acid (e.g., HCl)
V_a = 50.0  # Volume of acid (mL)
C_a = 10**(-0.5)   # Concentration of acid (M), adjusted for starting pH of 0.5

# Strong Base (e.g., NaOH)
C_b = 0.5   # Concentration of base (M)

# --- Calculation of pH at different points ---

V_b_initial = np.linspace(0, 0.1, 50)  # Before adding significant base
V_b_before_eq = np.linspace(0.1, V_a * C_a / C_b - 0.1, 100) # Before equivalence point
V_b_at_eq = np.array([V_a * C_a / C_b]) # At equivalence point
V_b_after_eq = np.linspace(V_a * C_a / C_b + 0.1, 100, 100) # After equivalence point

V_b_total = np.concatenate((V_b_initial, V_b_before_eq, V_b_at_eq, V_b_after_eq))

pH_values = []

for V_b in V_b_total:
    if V_b == 0:  # Initial pH before adding base
        pH = -np.log10(C_a)
    elif V_b < (V_a * C_a / C_b):  # Before equivalence point
        # Moles of H+ remaining
        moles_H_plus = (V_a * C_a - V_b * C_b) / 1000
        # Total volume in L
        total_volume_L = (V_a + V_b) / 1000
        # Concentration of H+
        H_plus_concentration = moles_H_plus / total_volume_L
        pH = -np.log10(H_plus_concentration)
    elif V_b == (V_a * C_a / C_b):  # At equivalence point
        pH = 7.0  # For strong acid-strong base titration
    else:  # After equivalence point
        # Moles of excess OH-
        moles_OH_minus = (V_b * C_b - V_a * C_a) / 1000
        # Total volume in L
        total_volume_L = (V_a + V_b) / 1000
        # Concentration of OH-
        OH_minus_concentration = moles_OH_minus / total_volume_L
        pOH = -np.log10(OH_minus_concentration)
        pH = 14 - pOH
    pH_values.append(pH)

# --- Plotting the Titration Curve ---

plt.figure(figsize=(8, 12))
plt.plot(V_b_total, pH_values, color='blue')
plt.title('Strong Acid vs. Strong Base Titration Curve')
plt.xlabel('Volume of Base Added (mL)')
plt.ylabel('pH')
plt.grid(True)
plt.axvline(x=V_a * C_a / C_b, color='red', linestyle='--', label='Equivalence Point')
plt.legend()
plt.ylim(0, 14) # pH scale typically ranges from 0 to 14
plt.show()
  

     
